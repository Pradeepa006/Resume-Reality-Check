# ─── Backend ───────────────────────────────────────
# Required: Get this from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyAufW_R63XSqNU4AUddgKct2YTZlVQkp1w

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-this-to-a-long-random-string

# Database (SQLite default, or use PostgreSQL for production)
# For SQLite: sqlite:///resumes.db
# For PostgreSQL: postgresql://user:password@host/dbname
DATABASE_URL=sqlite:///resumes.db

# CORS – comma-separated allowed origins (no trailing slash)
# Development: http://localhost:5173
# Production:  https://your-frontend-project.vercel.app
CORS_ORIGINS=http://localhost:5173

# Flask debug mode (set to False in production)
FLASK_DEBUG=True

# Port (default 5000)
PORT=5000

# ─── Frontend ──────────────────────────────────────
# Vercel deployment:
#   1. Deploy the backend project first to get its URL
#   2. In your FRONTEND Vercel project → Settings → Environment Variables, add:
#      VITE_API_URL = https://your-backend-project.vercel.app/api
# Leave empty to use the Vite proxy in local development
VITE_API_URL=https://resume-reality-check-api.vercel.app/api